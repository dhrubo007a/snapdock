# SnapDock Environment Configuration — copy to .env and fill in real values
# cp .env.example .env

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# 32-byte AES-256 key, base64url-encoded
# Generate: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
SNAPDOCK_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64URL_KEY=

# JWT signing secret (any long random string)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SNAPDOCK_JWT_SECRET=CHANGE_ME_LONG_RANDOM_HEX_STRING

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------

POSTGRES_DB=snapdock
POSTGRES_USER=snapdock
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Full DSN used by the SnapDock daemon (must match the values above)
SNAPDOCK_DATABASE_URL=postgresql+psycopg2://snapdock:CHANGE_ME_STRONG_PASSWORD@db:5432/snapdock

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

SNAPDOCK_STORAGE_PATH=/var/lib/snapdock/snapshots

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Set to true to enable debug logging
SNAPDOCK_DEBUG=false
