# SnapDock Daemon Configuration
# Copy this file to snapdock.env and fill in the required values.
# This file must NOT be committed to version control.
# Recommended permissions: chmod 600 snapdock.env

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# 32-byte AES-256 encryption key, base64url-encoded (no padding needed).
# Generate: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
SNAPDOCK_ENCRYPTION_KEY=

# Secret used to sign JWT tokens.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SNAPDOCK_JWT_SECRET=

# ---------------------------------------------------------------------------
# STORAGE
# ---------------------------------------------------------------------------

SNAPDOCK_STORAGE_PATH=/var/lib/snapdock/snapshots
SNAPDOCK_DB_PATH=/var/lib/snapdock/snapdock.db

# ---------------------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------------------

SNAPDOCK_HOST=0.0.0.0
SNAPDOCK_PORT=8000

# Never enable in production
SNAPDOCK_DEBUG=false

# ---------------------------------------------------------------------------
# DOCKER
# ---------------------------------------------------------------------------

SNAPDOCK_DOCKER_SOCKET=unix:///var/run/docker.sock

# ---------------------------------------------------------------------------
# TIMEOUTS (seconds)
# ---------------------------------------------------------------------------

SNAPDOCK_QUIESCE_TIMEOUT=30
SNAPDOCK_HEALTH_CHECK_TIMEOUT=120
SNAPDOCK_STOP_TIMEOUT=30

# ---------------------------------------------------------------------------
# NOTIFICATIONS — WEBHOOKS
# ---------------------------------------------------------------------------

# Comma-separated list of webhook URLs (Slack, Teams, PagerDuty, generic HTTP)
SNAPDOCK_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# NOTIFICATIONS — EMAIL (optional)
# Leave SNAPDOCK_SMTP_HOST empty to disable email notifications entirely.
# ---------------------------------------------------------------------------

SNAPDOCK_SMTP_HOST=
SNAPDOCK_SMTP_PORT=587
SNAPDOCK_SMTP_USER=
SNAPDOCK_SMTP_PASSWORD=
SNAPDOCK_SMTP_FROM=snapdock@example.com
# Comma-separated
SNAPDOCK_SMTP_TO=
